{
  "name": "obs-queuer",
  "version": "0.1.0",
  "description": "Electron app for OBS camera queue management with embedded web server for phone browsers",
  "main": "./out/main/index.js",
  "scripts": {
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3",
    "dev": "yarn rebuild:electron && electron-vite dev",
    "build": "yarn rebuild:electron && electron-vite build && vite build --config vite.config.web.ts",
    "build:web": "vite build --config vite.config.web.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "test": "yarn rebuild:node && vitest run",
    "test:watch": "yarn rebuild:node && vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.3",
    "obs-websocket-js": "^5.0.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ws": "^8.16.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.1.0",
    "electron-vite": "^2.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "supertest": "^7.2.2",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vitest": "^1.3.1"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
