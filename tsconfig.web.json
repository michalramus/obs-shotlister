{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": ["src/renderer/**/*", "src/web/**/*", "src/shared/**/*"],
  "compilerOptions": {
    "strict": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/*"],
      "@web/*": ["src/web/*"],
      "@shared/*": ["src/shared/*"]
    }
  }
}
